# ===== Database (Turso in production; local SQLite file in dev) =====
# Turso dashboard: https://turso.tech/app  → Database → "Generate Token"
# Scope: "read-and-write" to this database only (NOT org-wide).
# Rotate monthly. Dev keeps a local file under data/dev.db automatically.
DB_URL=libsql://<your-db>.turso.io
DB_AUTH_TOKEN=<turso-read-write-token>

# ===== GitHub OAuth App =====
# Register at https://github.com/settings/developers (or org settings).
# Homepage URL:    https://muscle-tracker-ten.vercel.app
# Callback URL:    https://muscle-tracker-ten.vercel.app/auth/github/callback
#                  (add http://localhost:5173/auth/github/callback for dev)
GITHUB_OAUTH_CLIENT_ID=<client-id>
GITHUB_OAUTH_CLIENT_SECRET=<client-secret>

# ===== Session cookie signing =====
# Generate with: `openssl rand -base64 32` (or any 32+ char random string).
# Rotate if leaked or every ~6 months. Rotation invalidates all existing sessions.
SESSION_SECRET=<32-char-random-string>

# ===== Access control =====
# Comma-separated GitHub usernames (not emails).
# Anyone whose `/user` API login is NOT in this list gets 403.
ALLOWED_GITHUB_USERS=yoshitetsu
